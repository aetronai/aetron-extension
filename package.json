{
  "name": "aetron-extension",
  "version": "0.0.2",
  "description": "Browser wallet extension for AETRON blockchain",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "scripts": {
    "dev": "BROWSER=chrome vite build --watch",
    "dev:chrome": "BROWSER=chrome vite build --watch",
    "dev:firefox": "BROWSER=firefox vite build --watch",
    "build": "npm run build:chrome",
    "build:chrome": "tsc && BROWSER=chrome vite build",
    "build:firefox": "tsc && BROWSER=firefox vite build",
    "build:all": "npm run build:chrome && npm run build:firefox",
    "package:chrome": "npm run build:chrome && ./scripts/package-extension.sh chrome",
    "package:firefox": "npm run build:firefox && ./scripts/package-extension.sh firefox",
    "package:all": "npm run build:all && ./scripts/package-extension.sh chrome && ./scripts/package-extension.sh firefox",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@polkadot/api": "^16.5.4",
    "@polkadot/keyring": "^14.0.2",
    "@polkadot/types": "^16.5.4",
    "@polkadot/util": "^14.0.2",
    "@polkadot/util-crypto": "^14.0.2",
    "buffer": "^6.0.3",
    "i18next": "^25.8.18",
    "lucide-react": "^0.577.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/chrome": "^0.1.37",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-static-copy": "^3.3.0"
  }
}
